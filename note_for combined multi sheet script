from pathlib import Path
from datetime import datetime
import pandas as pd


def combine_excels(input_dir: Path, output_dir: Path):
    excel_files = list(input_dir.glob("*.xlsx"))

    if not excel_files:
        print("No Excel files to combine.")
        return None

    dfs = []

    for file in excel_files:
        print(f"Processing file: {file.name}")

        # Read ALL sheets
        all_sheets = pd.read_excel(file, sheet_name=None)

        for sheet_name, df in all_sheets.items():
            print(f"  - Sheet: {sheet_name}")

            df["source_file"] = file.name
            df["sheet_name"] = sheet_name
            dfs.append(df)

    # Combine everything
    final_df = pd.concat(dfs, ignore_index=True)

    # Create timestamped output file
    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    output_file = output_dir / f"combined_{timestamp}.xlsx"

    final_df.to_excel(output_file, index=False)

    return output_file


# Entry point
if __name__ == "__main__":
    input_dir = Path("input")
    output_dir = Path("output")
    output_dir.mkdir(exist_ok=True)

    result = combine_excels(input_dir, output_dir)

    if result:
        print(f"\n✅ OUTPUT FILE CREATED: {result}")
    else:
        print("\n⚠️ No output generated.")
